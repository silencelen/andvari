{
    "cases": [
        {
            "name": "top-level-unknowns-rename",
            "docJson": "{\"type\":\"login\",\"name\":\"GitHub\",\"notes\":\"work account\",\"favorite\":false,\"login\":{\"username\":\"jacob\",\"password\":\"hunter2\",\"uris\":[\"https://github.com/login\"]},\"x-future\":{\"nested\":{\"deep\":true},\"arr\":[1,\"two\"]},\"x-tags\":[\"a\",\"b\"],\"x-note\":\"plain\"}",
            "edit": {
                "setName": "GitHub (renamed)"
            },
            "expectUnknownPaths": [
                {
                    "path": "/x-future",
                    "valueJson": "{\"nested\":{\"deep\":true},\"arr\":[1,\"two\"]}"
                },
                {
                    "path": "/x-tags",
                    "valueJson": "[\"a\",\"b\"]"
                },
                {
                    "path": "/x-note",
                    "valueJson": "\"plain\""
                }
            ],
            "expectTyped": [
                {
                    "path": "/name",
                    "valueJson": "\"GitHub (renamed)\""
                },
                {
                    "path": "/type",
                    "valueJson": "\"login\""
                },
                {
                    "path": "/login/username",
                    "valueJson": "\"jacob\""
                }
            ]
        },
        {
            "name": "login-unknowns-set-password",
            "docJson": "{\"type\":\"login\",\"name\":\"Email\",\"login\":{\"username\":\"jo@x.com\",\"password\":\"old-pass\",\"uris\":[],\"x-flag\":true,\"x-order\":7,\"x-null\":null}}",
            "edit": {
                "setPassword": "n3w-p4ss!"
            },
            "expectUnknownPaths": [
                {
                    "path": "/login/x-flag",
                    "valueJson": "true"
