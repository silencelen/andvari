                    "path": "/login/passwordHistory/1/x-meta",
                    "valueJson": "{\"source\":\"import\",\"gen\":2}"
                }
            ],
            "expectTyped": [
                {
                    "path": "/favorite",
                    "valueJson": "true"
                },
                {
                    "path": "/login/passwordHistory/0/password",
                    "valueJson": "\"pw1\""
                },
                {
                    "path": "/login/passwordHistory/1/retiredAt",
                    "valueJson": "1710000000000"
                }
            ]
        },
