                {
                    "path": "/login/username",
                    "valueJson": "\"jo@x.com\""
                },
                {
                    "path": "/name",
                    "valueJson": "\"Email\""
                }
            ]
        },
        {
            "name": "history-entry-unknowns-favorite",
            "docJson": "{\"type\":\"login\",\"name\":\"Bank\",\"favorite\":false,\"login\":{\"username\":\"jo\",\"password\":\"pw3\",\"passwordHistory\":[{\"password\":\"pw1\",\"retiredAt\":1700000000000,\"x-note\":\"rotated after breach\"},{\"password\":\"pw2\",\"retiredAt\":1710000000000,\"x-meta\":{\"source\":\"import\",\"gen\":2}}]}}",
