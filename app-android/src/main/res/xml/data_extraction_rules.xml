<?xml version="1.0" encoding="utf-8"?>
<!--
  API 31+ backup/transfer rules. On Android 12+ (this app targets 35),
  device-to-device transfer runs EVEN with allowBackup="false", so the session
  prefs — refresh token + cached accountKeys ciphertext (offline unlock,
  spec 02 §8) — must be excluded here explicitly. The durable vault cache
  (vault-<userId>.db) lives in noBackupFilesDir, which sits outside every
  backup/transfer domain by construction, so it needs no rule.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="andvari.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="andvari.xml" />
    </device-transfer>
</data-extraction-rules>
