<?xml version="1.0" encoding="utf-8"?>
<!--
  The public default server is HTTPS; cleartext is permitted ONLY to loopback and the
  emulator host, for local development and localhost self-hosting — nothing else.
  Self-hosters serving over plain http on a LAN should front their server with HTTPS
  (reverse proxy / tailscale serve / cloudflared) instead of widening this config.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
