<?xml version="1.0" encoding="utf-8"?>
<!--
  andvari default server is the LAN/VLAN2 host 192.168.2.122 over plain HTTP (the
  tailnet + LAN are the trust boundary; TLS is added by tailscale serve / cloudflared
  when off-LAN). Cleartext is allowed ONLY to that host and loopback, nothing else.
  The devstore Android app uses the same pattern.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.2.122</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
