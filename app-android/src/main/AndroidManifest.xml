<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Package visibility (API 30+): without this, PackageManager.getPackageInfo throws
         NameNotFound for every browser, so the autofill signing-cert check (TrustedBrowsers)
         always fails closed and NOTHING ever fills. One <package> per key in
         core BrowserCertPins.TABLE — keep the two lists in lockstep. A fixed allowlist, so
         no QUERY_ALL_PACKAGES (that carries Play-policy weight and isn't needed here). -->
    <queries>
        <!-- Chrome + channels -->
        <package android:name="com.android.chrome" />
        <package android:name="com.chrome.beta" />
        <package android:name="com.chrome.dev" />
        <package android:name="com.chrome.canary" />
        <package android:name="com.google.android.apps.chrome" />
        <!-- Firefox + channels -->
        <package android:name="org.mozilla.firefox" />
        <package android:name="org.mozilla.firefox_beta" />
        <package android:name="org.mozilla.fenix" />
        <package android:name="org.mozilla.focus" />
        <package android:name="org.mozilla.klar" />
        <!-- Samsung Internet -->
        <package android:name="com.sec.android.app.sbrowser" />
        <package android:name="com.sec.android.app.sbrowser.beta" />
        <!-- Others (fail-closed until a digest is captured on-device) -->
        <package android:name="com.microsoft.emmx" />
        <package android:name="com.brave.browser" />
        <package android:name="com.opera.browser" />
        <package android:name="com.opera.gx" />
        <package android:name="com.vivaldi.browser" />
        <package android:name="com.duckduckgo.mobile.android" />
        <package android:name="com.kiwibrowser.browser" />
        <package android:name="org.torproject.torbrowser" />
    </queries>

    <application
        android:name="io.silencelen.andvari.app.AndvariApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:label="andvari"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.Andvari">
        <!-- Handle config changes in-process: rotation / fold-posture (screenLayout|
             smallestScreenSize|screenSize) / dark-mode etc. must NOT recreate the
             Activity — recreation silently wiped typed editor state and orphaned
             in-flight saves. Compose recomposes on configuration change on its own; no
             manual onConfigurationChanged needed. -->
        <activity
            android:name="io.silencelen.andvari.app.MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboardHidden|keyboard|density|uiMode|locale|fontScale"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Andvari">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Autofill (Phase 6, fill-only). Fully-qualified android:name — the source
             package io.silencelen.andvari.app is NOT the manifest namespace
             com.silencelen.andvari (burned gotcha: relative names crash pre-main). -->
        <service
            android:name="io.silencelen.andvari.app.autofill.AndvariAutofillService"
            android:exported="true"
            android:label="andvari"
            android:permission="android.permission.BIND_AUTOFILL_SERVICE">
            <intent-filter>
                <action android:name="android.service.autofill.AutofillService" />
            </intent-filter>
            <meta-data
                android:name="android.autofill"
                android:resource="@xml/autofill_service" />
        </service>
        <activity
            android:name="io.silencelen.andvari.app.autofill.AutofillUnlockActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Andvari.Translucent" />
        <!-- "Save to andvari?" confirm/unlock overlay (autofill onSaveRequest). -->
        <activity
            android:name="io.silencelen.andvari.app.autofill.SaveConfirmActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Andvari.Translucent" />
        <!-- "Trust {browser} to fill here" confirm, launched from the autofill dropdown row. -->
        <activity
            android:name="io.silencelen.andvari.app.autofill.TrustBrowserActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:theme="@style/Theme.Andvari.Translucent" />

        <!-- ProfileInstaller auto-init runs in the androidx.startup provider BEFORE
             Application.onCreate and has caused immediate startup crashes on some Android 15
             / OEM builds. It is a perf-only optimization (baseline profiles); disable the
             auto-init to rule it out. emoji2 + lifecycle initializers are kept (Compose needs
             emoji2). -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                tools:node="remove" />
        </provider>
    </application>
</manifest>
