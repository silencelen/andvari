{
  "manifest_version": 3,
  "name": "andvari",
  "version": "0.16.4",
  "description": "Zero-knowledge password manager — fill and save logins. Works with any andvari server; set your own in Options.",
  "browser_specific_settings": {
    "gecko": {
      "id": "andvari@monahanhosting.com",
      "strict_min_version": "121.0",
      "update_url": "https://andvari.monahanhosting.com/downloads/firefox-updates.json"
    }
  },
  "permissions": ["storage", "activeTab", "scripting", "alarms", "clipboardWrite"],
  "host_permissions": [
    "https://andvari.monahanhosting.com/*",
    "https://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "options_ui": { "page": "options.html", "open_in_tab": true },
  "background": { "scripts": ["background.js"], "type": "module" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "andvari",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
