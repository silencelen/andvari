{
  "manifest_version": 3,
  "name": "andvari",
  "version": "0.6.0",
  "description": "Zero-knowledge password manager — fill and save logins. Requires the andvari server on your Tailscale network.",
  "permissions": ["storage", "activeTab", "scripting", "alarms"],
  "host_permissions": ["https://andvari.taila2dff2.ts.net/*"],
  "background": { "service_worker": "background.js", "type": "module" },
  "action": { "default_popup": "popup.html", "default_title": "andvari" },
  "content_scripts": [
    { "matches": ["http://*/*", "https://*/*"], "js": ["content.js"], "run_at": "document_idle" }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
